# =============================================================================
# Mapky frontend — environment variables
# =============================================================================
#
# All Vite vars are read at BUILD time. Override only what you need; defaults
# in src/lib/config.ts are picked from VITE_PUBKY_ENV. Production builds with
# VITE_PUBKY_ENV=production already point at the live homeserver, relay, and
# nexus, so most of the Pubky block below can stay commented.
#
# In dev, the Vite proxy at vite.config.ts handles /v0/mapky → nexus,
# /nominatim → Nominatim, and /valhalla → valhalla.openstreetmap.de. The URL
# defaults below mirror that.

# ─── Pubky environment ───────────────────────────────────────────────
# Picks the default homeserver pubkey, relay, and nexus URL for the
# selected environment. Any explicit VITE_* override below wins.
#   testnet   — local pubky-docker stack (homeserver on :6286, etc.)
#   staging   — homeserver.staging.pubky.app
#   production — homeserver.pubky.app
VITE_PUBKY_ENV=testnet

# ─── Pubky homeserver ────────────────────────────────────────────────
# z-base32 pubkey of the homeserver this app reads/writes against.
# Override only when running your own homeserver. The defaults are:
#   testnet:    8pinxxgqs41n4aididenw5apqp1urfmzdztr8jt4abrkdn435ewo
#   staging:    ufibwbmed6jeq9k4p583go95wofakh9fwpp4k734trq79pd9u1uy
#   production: ufibwbmed6jeq9k4p583go95wofakh9fwpp4k734trq79pd9u1uy
# VITE_PUBKY_HOMESERVER=
# Direct HTTPS URL for the homeserver (used for the recovery-file flow).
# Defaults to http://localhost:6286 (testnet), https://homeserver.staging.pubky.app
# (staging), https://homeserver.pubky.app (production).
# VITE_PUBKY_HOMESERVER_URL=

# ─── Pubky relay (Pubky Ring QR sign-in) ─────────────────────────────
# Defaults to http://localhost:15412/link (testnet),
# https://httprelay.staging.pubky.app/link/ (staging),
# https://httprelay.pubky.app/link/ (production).
# VITE_PUBKY_RELAY=

# ─── Pkarr DHT relays ────────────────────────────────────────────────
# Comma-separated list of pkarr relay URLs. Used to publish/resolve
# user keys in production. Ignored on testnet.
# VITE_PKARR_RELAYS=https://pkarr.pubky.app,https://pkarr.pubky.org

# ─── Pubky-nexus REST API ────────────────────────────────────────────
# Base URL of the nexus indexer (with the mapky plugin compiled in).
# Defaults: http://localhost:8080 (testnet), https://nexus.mapky.app
# (staging), https://nexus.mapky.app (production).
# VITE_NEXUS_URL=https://api.mapky.yourdomain.tld

# ─── Pubky CDN / gateway (avatars, attachments) ──────────────────────
# Defaults to the same host as VITE_NEXUS_URL with /static/files and
# /static/avatar paths. Override when you proxy uploads separately.
# VITE_PUBKY_GATEWAY=
# VITE_PUBKY_GATEWAY_BASE_FILE_PATH=/static/files
# VITE_PUBKY_GATEWAY_BASE_AVATAR_PATH=/static/avatar

# ─── Profile data path on the homeserver ─────────────────────────────
# VITE_PUBKY_PROFILE_PATH=/pub/pubky.app/profile.json

# ─── Protomaps vector tiles ──────────────────────────────────────────
# Get a free key at https://app.protomaps.com/. Required for the basemap.
VITE_PROTOMAPS_URL=https://api.protomaps.com/tiles/v4.pmtiles
VITE_PROTOMAPS_KEY=

# ─── OSM auxiliary services ──────────────────────────────────────────
# All three default to public free instances; each rate-limits per IP
# and should be swapped for a self-hosted or paid endpoint before any
# real launch.
#
# Nominatim — POI lookups, place names, category icons.
#   Dev default: /nominatim (proxied through Vite)
#   Prod default: https://nominatim.openstreetmap.org
# VITE_NOMINATIM_URL=https://nominatim.yourdomain.tld
#
# Overpass — Bitcoin overlay POI queries (BTCMap tag schema).
#   Default: https://overpass-api.de/api/interpreter
# VITE_OVERPASS_URL=https://overpass.yourdomain.tld/api/interpreter
#
# Valhalla — turn-by-turn directions snapping.
#   Dev default: /valhalla/route (proxied through Vite)
#   Prod default: https://valhalla1.openstreetmap.de/route
# VITE_VALHALLA_URL=https://valhalla.yourdomain.tld/route
