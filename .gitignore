# Dependencies
node_modules/

# Build
dist/
dist-ssr/
# TanStack Router plugin's transient cache — only the generated
# routeTree.gen.ts (under src/) is tracked.
.tanstack/

# E2E artifacts — screenshots, results.json, exported GPX are generated
# every run. The driver scripts (e2e/*.mjs, e2e/README.md) stay tracked.
e2e/output/

# Playwright MCP smoke-test scratch — screenshots, console/network logs
# the MCP browser tool drops into the cwd of whatever spawned it.
.playwright-mcp/

# Environment
.env
.env.local
*.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log
npm-debug.log*

# Testing
coverage/

# TanStack Router (auto-generated). Tracked in git so CI's `tsc -b` step
# can run before vite has had a chance to regenerate it. Local dev still
# regenerates on every save via the router-plugin — just remember to
# commit the diff when you add or rename a route.
